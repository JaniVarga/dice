class DiceImageProcessor():
    def __init__(self, image_path: str, resize_width: int = 400) -> None:
        self.img = image_path
        self.resize_width = resize_width

    def load_image(self) -> npt.NDArray[np.uint8]:
        img =cv2.imread(self.img, cv2.IMREAD_COLOR)
        if img is None:
            raise FileNotFoundError(f"Image could not be loaded: {self.img}")
        return img

